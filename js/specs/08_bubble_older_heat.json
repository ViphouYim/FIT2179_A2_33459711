{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "data": { "url": "data/combined_sa2.csv" },
  "params": [
    { "name": "stateFilter", "value": null }
  ],
  "transform": [
    { "filter": "stateFilter == null || datum.state_name == stateFilter" },
    { "filter": "isFinite(toNumber(datum.exposure_index)) && isFinite(toNumber(datum.pct_65_plus_2024)) && isFinite(toNumber(datum.hhri))" },
    { "calculate": "toNumber(datum.exposure_index)", "as": "exp" },
    { "calculate": "toNumber(datum.pct_65_plus_2024)", "as": "pct_older" },
    { "calculate": "toNumber(datum.hhri)", "as": "hhri_num" }
  ],
  "mark": { "type": "rect" },
  "encoding": {
    "x": {
      "field": "exp",
      "type": "quantitative",
      "bin": { "maxbins": 10 },
      "title": "Heat exposure index",
      "axis": { "labelAngle": 0, "format": ".1f" }
    },
    "y": {
      "field": "pct_older",
      "type": "quantitative",
      "bin": { "maxbins": 10 },
      "title": "% population aged 65+"
    },
    "color": {
      "aggregate": "mean",
      "field": "hhri_num",
      "type": "quantitative",
      "title": "Avg HHRI",
      "scale": {
        "domain": [0, 1],
        "range": ["#fff3c4", "#f9a84b", "#f28e2b", "#c4410c", "#8c2d04"]
      },
      "legend": {
        "orient": "right",
        "gradientLength": 160,
        "title": "Avg HHRI",
        "titleFontSize": 11,
        "labelFontSize": 10
      }
    },
    "tooltip": [
      { "field": "exp", "bin": true, "format": ".2f", "title": "Exposure" },
      { "field": "pct_older", "bin": true, "format": ".1f", "title": "% aged 65+" },
      { "aggregate": "mean", "field": "hhri_num", "format": ".3f", "title": "Avg HHRI" },
      { "aggregate": "count", "title": "SA2s in cell" }
    ]
  },
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": { "labelColor": "#374151", "titleColor": "#111827" }
  }
}
