{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 330,
  "data": { "url": "data/combined_sa2.csv" },
  "params": [
    {
      "name": "stateFilter3",
      "value": null,
      "bind": {
        "input": "select",
        "options": [null, "Australian Capital Territory", "New South Wales", "Northern Territory", "Queensland", "South Australia", "Tasmania", "Victoria", "Western Australia"],
        "labels": ["All states", "ACT", "NSW", "NT", "QLD", "SA", "TAS", "VIC", "WA"],
        "name": "Filter by state: "
      }
    }
  ],
  "layer": [
    {
      "description": "Shaded priority zone: high exposure + high older population",
      "data": { "values": [{ "x1": 0.5, "x2": 1, "y1": 18, "y2": 55 }] },
      "mark": { "type": "rect", "color": "#c4410c", "opacity": 0.09 },
      "encoding": {
        "x":  { "field": "x1", "type": "quantitative", "scale": { "domain": [0, 1] } },
        "x2": { "field": "x2" },
        "y":  { "field": "y1", "type": "quantitative", "scale": { "domain": [0, 55] } },
        "y2": { "field": "y2" }
      }
    },
    {
      "description": "Dashed divider lines",
      "data": { "values": [{ "mid_x": 0.5, "mid_y": 18 }] },
      "layer": []
    },
    {
      "description": "Vertical midline at exposure = 0.5",
      "data": { "values": [{ "mid": 0.5 }] },
      "mark": { "type": "rule", "strokeDash": [4, 3], "color": "#9e8e7e", "opacity": 0.45, "strokeWidth": 1 },
      "encoding": { "x": { "field": "mid", "type": "quantitative" } }
    },
    {
      "description": "Priority zone label",
      "data": { "values": [{ "x": 0.98, "y": 54, "label": "\u2197 PRIORITY ZONE: older + high exposure" }] },
      "mark": {
        "type": "text", "align": "right", "baseline": "top",
        "fontSize": 8.5, "fontWeight": "bold", "color": "#8c3010", "opacity": 0.82
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative" },
        "text": { "field": "label" }
      }
    },
    {
      "description": "SA2 bubbles",
      "transform": [
        { "filter": "stateFilter3 == null || datum.state_name == stateFilter3" },
        { "filter": "isFinite(toNumber(datum.exposure_index)) && isFinite(toNumber(datum.pct_65_plus_2024)) && isFinite(toNumber(datum.hhri))" },
        { "calculate": "toNumber(datum.exposure_index)", "as": "exp" },
        { "calculate": "toNumber(datum.pct_65_plus_2024)", "as": "pct_older" },
        { "calculate": "toNumber(datum.hhri)", "as": "hhri_num" },
        { "calculate": "toNumber(datum.population_hhri_2022)", "as": "pop" },
        {
          "calculate": "datum.hhri_num < 0.4 ? 'Low risk' : datum.hhri_num < 0.7 ? 'Medium risk' : 'High risk'",
          "as": "risk_band"
        }
      ],
      "mark": { "type": "circle", "opacity": 0.70, "stroke": "#5a3a28", "strokeWidth": 0.4 },
      "encoding": {
        "x": {
          "field": "exp", "type": "quantitative",
          "title": "Heat exposure index",
          "scale": { "domain": [0, 1] }
        },
        "y": {
          "field": "pct_older", "type": "quantitative",
          "title": "% population aged 65+",
          "scale": { "domain": [0, 55] }
        },
        "size": {
          "field": "pop", "type": "quantitative",
          "scale": { "range": [15, 700], "type": "sqrt" },
          "legend": {
            "title": "Population", "orient": "bottom",
            "direction": "horizontal", "symbolFillColor": "#999",
            "values": [5000, 10000, 20000],
            "symbolLimit": 3
          }
        },
        "color": {
          "field": "risk_band", "type": "ordinal",
          "scale": {
            "domain": ["Low risk", "Medium risk", "High risk"],
            "range": ["#f6e8c3", "#f28e2b", "#7f0000"]
          },
          "legend": {
            "title": "HHRI risk band", "orient": "bottom",
            "direction": "horizontal"
          }
        },
        "tooltip": [
          { "field": "region_name", "title": "SA2" },
          { "field": "state_name", "title": "State" },
          { "field": "exp", "format": ".3f", "title": "Exposure index" },
          { "field": "pct_older", "format": ".1f", "title": "% aged 65+" },
          { "field": "hhri_num", "format": ".3f", "title": "HHRI" },
          { "field": "risk_band", "title": "Risk band" },
          { "field": "pop", "format": ",d", "title": "Population" }
        ]
      }
    }
  ],
  "resolve": { "scale": { "color": "independent", "size": "independent" } },
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": { "labelColor": "#374151", "titleColor": "#111827" },
    "title": {
      "font": "Georgia",
      "fontSize": 14,
      "subtitleFontSize": 11,
      "anchor": "start",
      "color": "#111827",
      "subtitleColor": "#5d5248"
    }
  }
}