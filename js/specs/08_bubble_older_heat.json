{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Are older communities more exposed to heat?",
  "data": {
    "url": "data/combined_sa2.csv"
  },
  "mark": {
    "type": "circle",
    "opacity": 0.3,
    "filled": true
  },
  "encoding": {
    "x": {
      "field": "exposure_index",
      "type": "quantitative",
      "title": "Heat exposure index"
    },
    "y": {
      "field": "pct_65_plus_2024",
      "type": "quantitative",
      "title": "% aged 65+"
    },
    "size": {
      "field": "population_age_2024",
      "type": "quantitative",
      "title": "Population",
      "scale": {
        "range": [
          8,
          180
        ]
      }
    },
    "color": {
      "field": "hhri",
      "type": "quantitative",
      "title": "HHRI",
      "scale": {
        "range": ["#f5f1e8", "#fdd9a0", "#f3a14a", "#d66a1f", "#8d3f18"]
      }
    },
    "tooltip": [
      "region_name",
      "state_name",
      {
        "field": "pct_65_plus_2024",
        "format": ".1f",
        "title": "% aged 65+"
      },
      {
        "field": "population_age_2024",
        "format": ",d",
        "title": "Population"
      },
      {
        "field": "hhri",
        "format": ".3f",
        "title": "HHRI"
      }
    ]
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}