{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "title": {
    "text": "Distribution of heat-health risk by state/territory",
    "subtitle": "Queensland highlighted \u00b7 States sorted highest to lowest median risk"
  },
  "data": { "url": "data/combined_sa2.csv" },
  "transform": [
    { "filter": "datum.state_name != 'Unknown' && datum.state_name != 'Other Territories' && isValid(datum.hhri)" }
  ],
  "layer": [
    {
      "description": "Boxplot with QLD highlighted",
      "mark": { "type": "boxplot", "extent": 1.5 },
      "encoding": {
        "x": {
          "field": "state_name", "type": "nominal",
          "sort": ["Northern Territory", "South Australia", "Queensland", "Tasmania", "Victoria", "Western Australia", "New South Wales", "Australian Capital Territory"],
          "title": null,
          "axis": {
            "labelAngle": 0, "labelFontSize": 11,
            "labelExpr": "datum.label == 'Northern Territory' ? 'NT' : datum.label == 'South Australia' ? 'SA' : datum.label == 'Queensland' ? 'QLD' : datum.label == 'Tasmania' ? 'TAS' : datum.label == 'Victoria' ? 'VIC' : datum.label == 'Western Australia' ? 'WA' : datum.label == 'New South Wales' ? 'NSW' : datum.label == 'Australian Capital Territory' ? 'ACT' : datum.label"
          }
        },
        "y": {
          "field": "hhri", "type": "quantitative",
          "title": "Heat-health risk score",
          "scale": { "domain": [0, 1] }
        },
        "color": {
          "condition": { "test": "datum.state_name == 'Queensland'", "value": "#c4410c" },
          "value": "#c8b89a"
        },
        "tooltip": [
          { "field": "state_name", "title": "State" },
          { "field": "hhri", "format": ".3f", "title": "HHRI" }
        ]
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": { "labelColor": "#374151", "titleColor": "#111827" },
    "title": {
      "font": "Georgia",
      "fontSize": 14,
      "subtitleFontSize": 11,
      "anchor": "start",
      "color": "#111827",
      "subtitleColor": "#5d5248"
    },
    "boxplot": {
      "median": { "color": "#8c2d04", "strokeWidth": 2.5 },
      "box": { "stroke": "#7a4820", "strokeWidth": 1.2 },
      "rule": { "color": "#7a4820", "strokeWidth": 1 },
      "ticks": { "color": "#7a4820", "size": 6 },
      "outliers": { "color": "#8c2d04", "size": 20, "opacity": 0.7 }
    }
  }
}