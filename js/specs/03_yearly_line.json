{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 80,
  "data": {
    "url": "data/section01_health_aihw_from_workbook.csv"
  },
  "transform": [
    {
      "filter": "datum.chart_group == 'Yearly hospitalisations'"
    },
    {
      "calculate": "toNumber(datum.hospitalisations)",
      "as": "hosp"
    },
    {
      "calculate": "format(datum.hosp, ',d')",
      "as": "hosp_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rect",
        "color": "#f5e8d6",
        "opacity": 0.42
      },
      "encoding": {
        "y": {
          "datum": 1000
        },
        "y2": {
          "datum": 1250
        }
      }
    },
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 1.2,
        "color": "#b8a896",
        "strokeDash": [4, 4]
      },
      "encoding": {
        "y": {
          "datum": 1000
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period == '2013-14'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": -20,
        "dy": -10,
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#6b5f55"
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal"
        },
        "y": {
          "datum": 1000
        },
        "text": {
          "value": "Threshold: 1,000"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#9a3412"
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal",
          "title": "Financial year",
          "axis": { "labelAngle": -35, "labelPadding": 6 }
        },
        "y": {
          "field": "hosp",
          "type": "quantitative",
          "title": "Hospitalisations",
          "scale": { "domain": [0, 1250] }
        },
        "tooltip": [
          { "field": "period", "title": "Financial year" },
          {
            "field": "hosp",
            "format": ",d",
            "title": "Hospitalisations"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 65,
        "color": "#ea580c"
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal",
          "title": "Financial year",
          "axis": { "labelAngle": -35, "labelPadding": 6 }
        },
        "y": {
          "field": "hosp",
          "type": "quantitative",
          "title": "Hospitalisations",
          "scale": { "domain": [0, 1250] }
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period == '2019-20'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "color": "#ea580c",
        "stroke": "#9a3412",
        "strokeWidth": 1.6
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal"
        },
        "y": {
          "field": "hosp",
          "type": "quantitative",
          "scale": { "domain": [0, 1250] }
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period == '2019-20'"
        }
      ],
      "mark": {
        "type": "text",
        "dx": 0,
        "dy": -18,
        "align": "center",
        "baseline": "bottom",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#7c2d12"
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal"
        },
        "y": {
          "field": "hosp",
          "type": "quantitative",
          "scale": { "domain": [0, 1250] }
        },
        "text": {
          "value": "Peak: 1,108"
        }
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    }
  }
}