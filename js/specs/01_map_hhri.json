{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 600,
  "title": {
    "text": "Heat-Health Risk Index by SA2",
    "subtitle": "Warm-grey areas are SA2s not included in the analysis \u00b7 Hover any region for details"
  },
  "data": {
    "url": "data/sa2_2021_analysis_australia.geojson",
    "format": {
      "type": "json",
      "property": "features"
    }
  },
  "transform": [
    {
      "lookup": "properties.SA2_CODE21",
      "from": {
        "data": {
          "url": "data/combined_sa2.csv"
        },
        "key": "region_code",
        "fields": [
          "region_name",
          "state_name",
          "hhri",
          "hhri_quintile",
          "exposure_index",
          "vulnerability_index",
          "housing_index",
          "health_status_index",
          "adaptive_capacity_index",
          "pct_65_plus_2024",
          "seifa_irsd_score"
        ]
      }
    },
    {
      "calculate": "toNumber(datum.hhri)",
      "as": "hhri_num"
    },
    {
      "filter": "isValid(datum.geometry) && indexof(datum.properties.SA2_NAME21, 'Migratory - Offshore - Shipping') < 0 && indexof(datum.properties.SA2_NAME21, 'No usual address') < 0 && datum.properties.STE_NAME21 != 'Other Territories'"
    },
    {
      "filter": "datum.properties.SA2_NAME21 != 'Kununurra'"
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -28
    ],
    "scale": 720
  },
  "params": [
    { "name": "stateFilter", "value": null }
  ],
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "fill": "#f8f1e6",
        "stroke": "#ede4d7",
        "strokeWidth": 0.12
      }
    },
    {
      "description": "No-data SA2s: visible fill + tooltip",
      "mark": { "type": "geoshape", "stroke": "#cfc3b4", "strokeWidth": 0.15 },
      "transform": [
        { "filter": "!isFinite(datum.hhri_num)" },
        { "calculate": "'Not included in analysis'", "as": "status" }
      ],
      "encoding": {
        "color": { "value": "#d6cdc1" },
        "tooltip": [
          { "field": "properties.SA2_NAME21", "title": "SA2" },
          { "field": "status", "title": "Status" }
        ]
      }
    },
    {
      "mark": {
        "type": "geoshape",
        "stroke": "#f4ecdf",
        "strokeWidth": 0.25
      },
      "transform": [
        {
          "filter": "isFinite(datum.hhri_num)"
        }
      ],
      "encoding": {
        "color": {
          "field": "hhri_num",
          "type": "quantitative",
          "title": "HHRI",
          "scale": {
            "range": ["#fff7bc", "#fec44f", "#fe9929", "#d95f0e", "#993404"],
            "domain": [0, 0.25, 0.5, 0.75, 1]
          }
        },
        "opacity": {
          "condition": {"test": "stateFilter == null || datum.state_name == stateFilter", "value": 1},
          "value": 0.12
        },
        "tooltip": [
          {
            "field": "region_name",
            "title": "SA2"
          },
          {
            "field": "state_name",
            "title": "State"
          },
          {
            "field": "hhri_num",
            "type": "quantitative",
            "format": ".3f",
            "title": "HHRI"
          },
          {
            "field": "hhri_quintile",
            "title": "Risk quintile"
          },
          {
            "field": "exposure_index",
            "format": ".3f",
            "title": "Heat exposure"
          },
          {
            "field": "housing_index",
            "format": ".3f",
            "title": "Housing condition"
          },
          {
            "field": "health_status_index",
            "format": ".3f",
            "title": "Health status"
          },
          {
            "field": "pct_65_plus_2024",
            "format": ".1f",
            "title": "% aged 65+"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "geoshape",
        "fill": null,
        "stroke": "#d1c3b2",
        "strokeWidth": 0.3
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null,
      "fill": "transparent"
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}