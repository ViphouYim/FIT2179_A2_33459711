{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {"type": "fit-x", "contains": "padding"},
  "width": "container",
  "height": 320,
  "data": {
    "url": "data/top10_components_long.csv"
  },
  "mark": {
    "type": "rect"
  },
  "encoding": {
    "x": {
      "field": "component",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelAngle": -30
      }
    },
    "y": {
      "field": "region_name",
      "type": "nominal",
      "title": null,
      "sort": {"encoding": "color", "order": "descending"}
    },
    "color": {
      "field": "value",
      "type": "quantitative",
      "title": "Component score",
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 180
      },
      "scale": {
        "domain": [0, 1],
        "range": ["#f5f1e8", "#fee391", "#fe9929", "#d95f0e", "#8b4513"]
      }
    },
    "tooltip": [
      "region_name",
      "state_name",
      "component",
      {
        "field": "value",
        "format": ".3f"
      }
    ]
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}