{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {"type": "fit-x", "contains": "padding"},
  "width": "container",
  "height": 440,
  "data": {
    "url": "data/top10_components_long.csv"
  },
  "params": [
    {
      "name": "sa2Click",
      "select": {
        "type": "point",
        "fields": ["region_name"],
        "on": "click",
        "clear": "dblclick"
      }
    }
  ],
  "mark": {
    "type": "rect",
    "cursor": "pointer"
  },
  "encoding": {
    "x": {
      "field": "component",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelAngle": 0,
        "labelExpr": "datum.label == 'Adaptive capacity' ? 'Adaptive' : datum.label == 'Health status' ? 'Health' : datum.label == 'Heat exposure' ? 'Exposure' : datum.label == 'Housing condition' ? 'Housing' : datum.label"
      }
    },
    "y": {
      "field": "region_name",
      "type": "nominal",
      "title": null,
      "sort": {"encoding": "color", "order": "descending"}
    },
    "color": {
      "field": "value",
      "type": "quantitative",
      "title": "Component score",
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 240
      },
      "scale": {
        "domain": [0, 1],
        "range": ["#fdf6ec", "#fdd49e", "#f28e2b", "#c4410c", "#8c2d04"]
      }
    },
    "opacity": {
      "condition": {"param": "sa2Click", "value": 1},
      "value": 0.4
    },
    "tooltip": [
      "region_name",
      "state_name",
      "component",
      {
        "field": "value",
        "format": ".3f"
      }
    ]
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}