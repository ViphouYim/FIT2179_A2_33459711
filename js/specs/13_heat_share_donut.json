{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 250,
  "data": {
    "values": [
      {"group": "Heat", "hospitalisations": 7104, "share": 0.7790},
      {"group": "Other weather events", "hospitalisations": 2015, "share": 0.2210}
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 52,
        "outerRadius": 88,
        "cornerRadius": 3
      },
      "encoding": {
        "theta": {
          "field": "hospitalisations",
          "type": "quantitative"
        },
        "color": {
          "field": "group",
          "type": "nominal",
          "scale": {
            "domain": [
              "Heat",
              "Other weather events"
            ],
            "range": [
              "#c2410c",
              "#d6c4af"
            ]
          },
          "legend": {
            "orient": "bottom",
            "title": null,
            "labelColor": "#4b5563"
          }
        },
        "tooltip": [
          "group",
          {
            "field": "hospitalisations",
            "format": ",d"
          },
          {
            "field": "share",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.group == 'Heat'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Georgia",
        "fontSize": 32,
        "fontWeight": 700,
        "color": "#7c2d12"
      },
      "encoding": {
        "text": {
          "field": "share",
          "format": ".0%"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.group == 'Heat'"
        }
      ],
      "mark": {
        "type": "text",
        "dy": 26,
        "fontSize": 11,
        "color": "#6b5f55"
      },
      "encoding": {
        "text": {
          "value": "7,104 of 9,119"
        }
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    }
  }
}
