{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "title": {
    "text": "Where housing and health risk cluster together",
    "subtitle": "Each cell = a group of SA2s with similar scores \u00b7 Colour = mean HHRI in that bin \u00b7 Hover for detail"
  },
  "data": { "url": "data/combined_sa2.csv" },
  "params": [
    {
      "name": "stateFilter2",
      "value": null,
      "bind": {
        "input": "select",
        "options": [null, "Australian Capital Territory", "New South Wales", "Northern Territory", "Queensland", "South Australia", "Tasmania", "Victoria", "Western Australia"],
        "labels": ["All states", "ACT", "NSW", "NT", "QLD", "SA", "TAS", "VIC", "WA"],
        "name": "Filter by state: "
      }
    }
  ],
  "transform": [
    { "filter": "stateFilter2 == null || datum.state_name == stateFilter2" },
    { "filter": "isFinite(toNumber(datum.housing_index)) && isFinite(toNumber(datum.health_status_index))" }
  ],
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "housing_index",
      "bin": { "maxbins": 10 },
      "type": "quantitative",
      "title": "Housing condition index"
    },
    "y": {
      "field": "health_status_index",
      "bin": { "maxbins": 10 },
      "type": "quantitative",
      "title": "Health status index"
    },
    "color": {
      "aggregate": "mean",
      "field": "hhri",
      "type": "quantitative",
      "title": "Mean HHRI",
      "scale": {
        "domain": [0, 1],
        "range": ["#fff7ec", "#fdd49e", "#f16913", "#7f2704"]
      },
      "legend": {
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 160,
        "titleFontSize": 11
      }
    },
    "tooltip": [
      { "bin": true, "field": "housing_index", "title": "Housing index bin" },
      { "bin": true, "field": "health_status_index", "title": "Health status bin" },
      { "aggregate": "mean", "field": "hhri", "format": ".3f", "title": "Mean HHRI" },
      { "aggregate": "count", "title": "SA2 count in cell" }
    ]
  },
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": { "labelColor": "#374151", "titleColor": "#111827" },
    "title": {
      "font": "Georgia",
      "fontSize": 14,
      "subtitleFontSize": 11,
      "anchor": "start",
      "color": "#111827",
      "subtitleColor": "#5d5248"
    }
  }
}
