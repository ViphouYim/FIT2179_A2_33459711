{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "title": "Average risk components by state/territory",
  "data": {
    "url": "data/state_components_long.csv"
  },
  "transform": [
    { "filter": "datum.state_name != 'Unknown' && datum.state_name != 'Other Territories'" }
  ],
  "mark": {
    "type": "bar"
  },
  "encoding": {
    "x": {
      "field": "state_name",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelAngle": -32,
        "labelFontSize": 9
      }
    },
    "y": {
      "field": "value",
      "type": "quantitative",
      "title": "Average index value",
      "stack": "normalize"
    },
    "color": {
      "field": "component",
      "type": "nominal",
      "title": "Component",
      "scale": {
        "domain": ["Heat exposure", "Vulnerability", "Housing condition", "Health status", "Adaptive capacity"],
        "range": ["#c2410c", "#e8883a", "#fabb6e", "#8d3f18", "#6f8797"]
      },
      "legend": {
        "orient": "bottom",
        "labelLimit": 0
      }
    },
    "tooltip": [
      "state_name",
      "component",
      {
        "field": "value",
        "format": ".3f"
      }
    ]
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}