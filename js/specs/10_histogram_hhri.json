{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 330,
  "title": "Which states contain more high-risk SA2s?",
  "data": {
    "url": "data/combined_sa2.csv"
  },
  "transform": [
    {
      "calculate": "toNumber(datum.hhri_quintile)",
      "as": "risk_level"
    },
    {
      "filter": "isFinite(datum.risk_level) && datum.risk_level >= 1 && datum.risk_level <= 5"
    },
    {
      "calculate": "datum.risk_level == 1 ? 'Lowest risk' : datum.risk_level == 2 ? 'Low risk' : datum.risk_level == 3 ? 'Moderate risk' : datum.risk_level == 4 ? 'High risk' : 'Highest risk'",
      "as": "risk_label"
    },
    {
      "aggregate": [
        {
          "op": "count",
          "as": "sa2_count"
        }
      ],
      "groupby": ["state_name", "risk_level", "risk_label"]
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "sa2_count",
          "as": "total_sa2"
        }
      ],
      "groupby": ["state_name"]
    },
    {
      "calculate": "datum.sa2_count / datum.total_sa2",
      "as": "share"
    },
    {
      "calculate": "datum.risk_label == 'Highest risk' ? format(datum.share, '.0%') : ''",
      "as": "highest_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "y": {
          "field": "state_name",
          "type": "nominal",
          "title": null,
          "sort": [
            "New South Wales",
            "Victoria",
            "Queensland",
            "South Australia",
            "Western Australia",
            "Tasmania",
            "Northern Territory",
            "Australian Capital Territory"
          ]
        },
        "x": {
          "field": "sa2_count",
          "type": "quantitative",
          "stack": "normalize",
          "title": "Share of SA2s"
        },
        "color": {
          "field": "risk_label",
          "type": "nominal",
          "title": "Risk level",
          "sort": ["Lowest risk", "Low risk", "Moderate risk", "High risk", "Highest risk"],
          "scale": {
            "domain": ["Lowest risk", "Low risk", "Moderate risk", "High risk", "Highest risk"],
            "range": ["#fff7bc", "#fee391", "#fec44f", "#fe9929", "#d95f0e"]
          },
          "legend": {
            "orient": "bottom"
          }
        },
        "tooltip": [
          {
            "field": "state_name",
            "title": "State"
          },
          {
            "field": "risk_label",
            "title": "Risk level"
          },
          {
            "field": "sa2_count",
            "type": "quantitative",
            "title": "SA2 count"
          },
          {
            "field": "share",
            "type": "quantitative",
            "title": "Share within state",
            "format": ".1%"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.risk_label == 'Highest risk'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 10,
        "fontWeight": 700,
        "color": "#4b3627"
      },
      "encoding": {
        "y": {
          "field": "state_name",
          "type": "nominal",
          "sort": [
            "New South Wales",
            "Victoria",
            "Queensland",
            "South Australia",
            "Western Australia",
            "Tasmania",
            "Northern Territory",
            "Australian Capital Territory"
          ]
        },
        "x": {
          "field": "share",
          "type": "quantitative",
          "stack": "normalize"
        },
        "text": {
          "field": "highest_label"
        }
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}