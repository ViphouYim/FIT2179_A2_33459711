{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": "Are disadvantaged areas facing higher heat risk?",
  "data": {
    "url": "data/combined_sa2.csv"
  },
  "mark": {
    "type": "circle",
    "opacity": 0.28,
    "size": 20,
    "filled": true
  },
  "encoding": {
    "x": {
      "field": "seifa_irsd_score",
      "type": "quantitative",
      "title": "SEIFA IRSD score (lower = more disadvantaged)"
    },
    "y": {
      "field": "hhri",
      "type": "quantitative",
      "title": "HHRI"
    },
    "color": {
      "field": "hhri_quintile",
      "type": "ordinal",
      "title": "HHRI quintile",
      "scale": {
        "range": ["#f5f1e8", "#fdd9a0", "#f3a14a", "#d66a1f", "#8d3f18"]
      }
    },
    "tooltip": [
      "region_name",
      "state_name",
      {
        "field": "seifa_irsd_score",
        "format": ".0f",
        "title": "SEIFA IRSD"
      },
      {
        "field": "seifa_irsd_decile",
        "format": ".0f",
        "title": "SEIFA decile"
      },
      {
        "field": "hhri",
        "format": ".3f",
        "title": "HHRI"
      }
    ]
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}