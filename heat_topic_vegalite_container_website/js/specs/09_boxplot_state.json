{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 330,
  "title": "Distribution of heat-health risk by state/territory",
  "data": {
    "url": "data/combined_sa2.csv"
  },
  "mark": {
    "type": "boxplot",
    "extent": "min-max"
  },
  "encoding": {
    "x": {
      "field": "state_name",
      "type": "nominal",
      "title": null,
      "axis": {
        "labelAngle": 0,
        "labelFontSize": 10
      }
    },
    "y": {
      "field": "hhri",
      "type": "quantitative",
      "title": "HHRI"
    },
    "color": {
      "field": "state_name",
      "type": "nominal",
      "legend": null
    }
  },
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    },
    "title": {
      "font": "Georgia",
      "fontSize": 18,
      "anchor": "start",
      "color": "#111827"
    }
  }
}