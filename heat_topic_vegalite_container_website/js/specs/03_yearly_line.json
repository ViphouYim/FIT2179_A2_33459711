{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 250,
  "data": {
    "url": "data/section01_health_aihw_from_workbook.csv"
  },
  "transform": [
    {
      "filter": "datum.chart_group == 'Yearly hospitalisations'"
    },
    {
      "calculate": "toNumber(datum.hospitalisations)",
      "as": "hosp"
    },
    {
      "calculate": "format(datum.hosp, ',d')",
      "as": "hosp_label"
    },
    {
      "calculate": "datum.hosp + 120",
      "as": "peak_label_y"
    }
  ],
  "encoding": {
    "x": {
      "field": "period",
      "type": "ordinal",
      "title": "Financial year",
      "axis": { "labelAngle": -35, "labelPadding": 6 }
    },
    "y": {
      "field": "hosp",
      "type": "quantitative",
      "title": "Hospitalisations"
    }
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 1,
        "color": "#b8a896",
        "strokeDash": [4, 4]
      },
      "encoding": {
        "y": {
          "datum": 1000
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -4,
        "fontSize": 10,
        "color": "#6b5f55"
      },
      "encoding": {
        "x": {
          "datum": "2012-13"
        },
        "y": {
          "datum": 1000
        },
        "text": {
          "value": "Threshold: 1,000"
        }
      }
    },
    {
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#9a3412"
      },
      "encoding": {
        "tooltip": [
          "period",
          {
            "field": "hosp",
            "format": ",d",
            "title": "Hospitalisations"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 65,
        "color": "#ea580c"
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period == '2019-20'"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeWidth": 1.5,
        "color": "#9a3412"
      },
      "encoding": {
        "x": {
          "field": "period",
          "type": "ordinal"
        },
        "y": {
          "field": "hosp",
          "type": "quantitative"
        },
        "y2": {
          "field": "peak_label_y"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.period == '2019-20'"
        }
      ],
      "mark": {
        "type": "text",
        "dx": 12,
        "dy": -22,
        "align": "left",
        "fontSize": 11,
        "fontWeight": 700,
        "color": "#7c2d12"
      },
      "encoding": {
        "y": {
          "field": "peak_label_y",
          "type": "quantitative"
        },
        "text": {
          "value": "Peak: 1,108"
        }
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#4b5563",
      "titleColor": "#111827",
      "gridColor": "#e8e1d7",
      "tickColor": "#d6cbbd"
    },
    "legend": {
      "labelColor": "#374151",
      "titleColor": "#111827"
    }
  }
}